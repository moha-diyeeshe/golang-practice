@authHeader = Bearer {{accessToken}}

#####################################
# Login — run this first so {{login.response.body...}} works (VS Code REST Client)
# If access_token is empty, try: {{login.response.body.$.access_token}}
#####################################

### Login
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "test2@gmail.com",
  "password": "password123"
}

#####################################
# Transactions (Bearer from Login)
# Use real customer_id / user_id from your DB (e.g. user id from JWT or users table)
#####################################

### List transactions
GET {{host}}/api/v1/transactions
Authorization: Bearer {{login.response.body.access_token}}

### Create transaction
POST {{host}}/api/v1/transactions
Authorization: Bearer {{login.response.body.access_token}}
Content-Type: application/json

{
  "customer_id": 4,
  "user_id": 11,
  "amount": 99.5,
  "txn_date": "2026-05-02"
}

### Get transaction by ID
GET {{host}}/api/v1/transactions/1
Authorization: Bearer {{login.response.body.access_token}}

### Update transaction
PUT {{host}}/api/v1/transactions/1
Authorization: Bearer {{login.response.body.access_token}}
Content-Type: application/json

{
  "amount": 120,
  "txn_date": "2026-05-03"
}

#####################################
# Manual token (set @accessToken at top)
#####################################

### List transactions (manual Bearer)
GET {{host}}/api/v1/transactions
Authorization: {{authHeader}}
